rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsExisting() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncoming() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn() && userId == request.auth.uid;
      allow create, update: if signedIn()
        && userId == request.auth.uid
        && ownsIncoming();
      allow delete: if false;
    }

    match /settings/{userId} {
      allow read: if signedIn() && userId == request.auth.uid;
      allow create, update: if signedIn()
        && userId == request.auth.uid
        && ownsIncoming();
      allow delete: if false;
    }

    match /hydration_logs/{document} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
      allow update, delete: if false;
    }

    match /daily_stats/{document} {
      allow read: if ownsExisting();
      allow create, update: if ownsIncoming();
      allow delete: if false;
    }

    match /achievements/{document} {
      allow read: if ownsExisting();
      allow create, update: if ownsIncoming();
      allow delete: if false;
    }

    match /streaks/{userId} {
      allow read: if signedIn() && userId == request.auth.uid && ownsExisting();
      allow create, update: if signedIn()
        && userId == request.auth.uid
        && ownsIncoming();
      allow delete: if false;
    }

    match /monthly_progress/{document} {
      allow read: if ownsExisting();
      allow create, update: if ownsIncoming();
      allow delete: if false;
    }

    match /fcm_tokens/{document} {
      allow read: if ownsExisting();
      allow create, update: if ownsIncoming();
      allow delete: if ownsExisting();
    }

    match /notification_schedules/{userId} {
      allow read: if signedIn() && userId == request.auth.uid && ownsExisting();
      allow create, update: if signedIn()
        && userId == request.auth.uid
        && ownsIncoming();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
